# Supabase (public)
#
# For Next.js/browser builds you typically need the `NEXT_PUBLIC_` prefix.
# For server/CLI/edge-function contexts, `SUPABASE_URL`/`SUPABASE_ANON_KEY` are common.
#
# Recommended: set both pairs to the same values when applicable.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Supabase (server-only)
# Never expose this in the browser.
SUPABASE_SERVICE_ROLE_KEY=
