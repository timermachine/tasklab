# Repo-local Supabase values (copy once, then scripts read from here).
#
# 1) Copy this file to `.env` (gitignored).
# 2) Fill values from the Supabase dashboard (Project Settings → API).
#
# Used by TaskLab scripts (linking, hosted smoke, CI setup).
SUPABASE_PROJECT_REF=
SUPABASE_URL=
# Prefer legacy JWT anon key for Edge Functions JWT verification.
SUPABASE_ANON_KEY=

