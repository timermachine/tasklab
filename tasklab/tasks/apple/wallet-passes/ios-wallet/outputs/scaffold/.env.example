# Required
PASS_TYPE_IDENTIFIER="pass.com.example.my-pass"
TEAM_IDENTIFIER="ABCDE12345"

# Optional pass fields
SERIAL_NUMBER="demo-0001"
ORGANIZATION_NAME="TaskLab"
DESCRIPTION="TaskLab demo pass"
LOGO_TEXT="TaskLab"
PRIMARY_LABEL="Member"
PRIMARY_VALUE="Example"
BARCODE_MESSAGE="tasklab"
BARCODE_FORMAT="PKBarcodeFormatQR"

# Optional colors (CSS-like `rgb(r,g,b)` strings)
FOREGROUND_COLOR="rgb(255,255,255)"
BACKGROUND_COLOR="rgb(0,0,0)"
LABEL_COLOR="rgb(255,255,255)"

# Signing inputs (required only for signed `.pkpass`)
PASS_P12_PATH=""
PASS_P12_PASSWORD=""
WWDR_CERT_PATH=""

