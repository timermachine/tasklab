# Google Wallet passes (Generic)
#
# Copy this file to `.env` in your target project root (gitignore it).
# Scripts read from `.env` so you only copy values once.

# Google Cloud project id (for operator context + logs)
# - Open https://console.cloud.google.com/home/dashboard
# - Use the project picker (top bar) and copy "Project ID" (not the project name)
GCP_PROJECT_ID=

# Issuer ID (numeric string)
# - Open https://pay.google.com/business/console/
# - Select the correct business/issuer, then find/copy "Issuer ID"
# - If you can't find it, use console search for "issuer" or "ID"
ISSUER_ID=

# Service account JSON key path (absolute path, never commit)
# - Create/download JSON key from https://console.cloud.google.com/iam-admin/serviceaccounts
#   Service Accounts → pick the account → Keys → Add key → Create new key → JSON → download
# - Then set this to the absolute path on your machine, e.g. /Users/<you>/Downloads/key.json
GOOGLE_APPLICATION_CREDENTIALS=

# Pass identifiers (use safe, unique suffixes)
CLASS_SUFFIX=tasklab_generic
OBJECT_SUFFIX=demo_001

# Computed IDs (scripts will derive these; you can override if needed)
# CLASS_ID=${ISSUER_ID}.${CLASS_SUFFIX}
# OBJECT_ID=${ISSUER_ID}.${OBJECT_SUFFIX}

# Human-visible title on the pass
PASS_TITLE="TaskLab Generic Pass"
