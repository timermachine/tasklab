# Stripe (test mode) integration values
# - Put this file in your project root as `.env` (gitignored)
# - Keep secrets out of git and out of reports

# Required
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# Local app + webhook settings
STRIPE_WEBHOOK_PORT=4242
STRIPE_WEBHOOK_PATH=/webhook

# Optional: override Stripe API version used by the sample app (leave blank to use the stripe-node default)
STRIPE_API_VERSION=

# Checkout redirect URLs
STRIPE_SUCCESS_URL=http://localhost:4242/success
STRIPE_CANCEL_URL=http://localhost:4242/cancel

# Webhook security
STRIPE_WEBHOOK_TOLERANCE_SECONDS=300
STRIPE_WEBHOOK_DEDUPE_TTL_SECONDS=86400

