# Stripe webhooks (copy once, then scripts read from here)
#
# Copy this file to `.env` in your target project root (gitignore it).
#
# Source of truth for:
# - signing secret used to verify `Stripe-Signature`
# - local dev webhook port/path

# Local webhook endpoint (where Stripe CLI forwards to)
STRIPE_WEBHOOK_PORT=4242
STRIPE_WEBHOOK_PATH=/webhook

# Webhook signing secret (starts with whsec_)
# - If using Stripe CLI: `stripe listen --forward-to http://localhost:4242/webhook`
#   It prints: "Ready! Your webhook signing secret is whsec_..."
# - If using Workbench/Dashboard: Developers/Workbench → Webhooks → select destination → reveal Signing secret
STRIPE_WEBHOOK_SECRET=

# Replay defense (Stripe libraries default to 300 seconds)
# - Must be > 0. Recommended: 300 (5 min).
STRIPE_WEBHOOK_TOLERANCE_SECONDS=300

# Basic dedupe (recommended). Store event IDs for this TTL.
STRIPE_WEBHOOK_DEDUPE_TTL_SECONDS=86400

